{
  "version": 1,
  "planner": {
    "portfolio": "te-plan",
    "purpose": "Plan and orchestrate without owning workspace mutation.",
    "primary": {
      "provider": "github",
      "model": "github/gpt-5.4",
      "reason": "GitHub OAuth is active, and this route passed a tool-call probe."
    },
    "escalation": [
      {
        "provider": "codex",
        "model": "codex/gpt-5.6-sol-max",
        "reason": "Codex OAuth route passed a tool-call probe; use for difficult plans."
      },
      {
        "provider": "nebius",
        "model": "nebius/Qwen/Qwen3-235B-A22B-Instruct-2507",
        "reason": "Backbone fallback preserves planning capacity when subscription rails throttle."
      }
    ],
    "execution": "planning-only",
    "protect_from_worker_fanout": true
  },
  "dispatch": {
    "portfolio": "te-dispatch",
    "purpose": "Fan out independent work while protecting planner and premium limits.",
    "strategy": "role-sharded",
    "max_parallel": 4,
    "omniroute_workers": [
      {
        "role": "fast-worker",
        "provider": "command-code",
        "model": "command-code/deepseek/deepseek-v4-flash",
        "capability": "tool_calling",
        "cost_posture": "free-or-low-cost"
      },
      {
        "role": "coding-worker",
        "provider": "command-code",
        "model": "command-code/moonshotai/Kimi-K2.7-Code",
        "capability": "long-horizon-coding",
        "cost_posture": "subscription-or-provider-quota"
      },
      {
        "role": "build-worker",
        "provider": "grok-cli",
        "model": "grok-cli/grok-build",
        "capability": "coding-and-reasoning",
        "cost_posture": "subscription-or-provider-quota"
      },
      {
        "role": "backbone-worker",
        "provider": "nebius",
        "model": "nebius/Qwen/Qwen3-235B-A22B-Instruct-2507",
        "capability": "general-tool-capable",
        "cost_posture": "free-tier-or-api-budget"
      }
    ],
    "direct_cli_fallbacks": [
      {
        "backend": "command-code",
        "model": "deepseek/deepseek-v4-flash"
      },
      {
        "backend": "kimi",
        "model": "kimi-code/kimi-for-coding"
      },
      {
        "backend": "grok",
        "model": "grok-build"
      }
    ],
    "selection_rule": "Temperance freezes the plan; health, quota, capability, and circuit state rank eligible candidates.",
    "fail_open": "If the gateway or a provider is unavailable, dispatch retries the direct CLI rail, then Claude fallback."
  },
  "creative": {
    "portfolio": "te-creative",
    "purpose": "Plan creative work with Temperance context, then call native media contracts.",
    "planner_models": [
      "github/gpt-5.4",
      "codex/gpt-5.6-sol-max",
      "nebius/Qwen/Qwen3-235B-A22B-Instruct-2507"
    ],
    "native_providers": [
      {
        "provider": "elevenlabs",
        "connection_role": "media",
        "models": [
          "elevenlabs/eleven_multilingual_v2",
          "elevenlabs/eleven_turbo_v2_5"
        ],
        "endpoint": "/v1/audio/speech",
        "contract": "text-to-speech"
      },
      {
        "provider": "runwayml",
        "connection_role": "media",
        "models": [
          "runwayml/gen4.5",
          "runwayml/gen4_turbo"
        ],
        "endpoint": "/v1/videos/generations",
        "contract": "text-or-image-to-video"
      }
    ],
    "workflow": [
      "resolve-skill-cluster",
      "inject-temperance-context-and-isa-pointers",
      "create-creative-brief",
      "plan-with-te-creative",
      "invoke-native-media-contract",
      "validate-artifact-and-policy",
      "persist-artifact-and-evidence-pointer"
    ],
    "chat_combo_boundary": "Media models never enter a coding fallback chain; te-creative is the text planning rail only."
  },
  "writing": {
    "portfolio": "te-write",
    "purpose": "Draft Tryambakam Noesis long-form content on a governed sequential rail while a separate fusion council scores drift and gates every commit.",
    "skill": "noesis-writer-skill",
    "drafting_models": [
      "command-code/MiniMaxAI/MiniMax-M2.7",
      "nebius/moonshotai/Kimi-K2.6",
      "nebius/Qwen/Qwen3-235B-A22B-Instruct-2507"
    ],
    "critique": {
      "portfolio": "te-write-critique",
      "strategy": "fusion",
      "models": [
        "github/gpt-5.4",
        "codex/gpt-5.6-terra",
        "nebius/Qwen/Qwen3-235B-A22B-Instruct-2507"
      ],
      "judge_model": "codex/gpt-5.6-terra",
      "verdicts": ["COMMIT", "REGENERATE", "FLAG"],
      "scored_dimensions": [
        "voice-calibration",
        "vocabulary-contamination",
        "fractal-depth",
        "source-lattice",
        "albedo-claim-grammar"
      ]
    },
    "research": {
      "portfolio": "te-write-research",
      "strategy": "fusion",
      "purpose": "Build and ground the source lattice before drafting begins: triangulate independent research passes into one claim-classified synthesis.",
      "models": [
        "command-code/deepseek/deepseek-v4-pro",
        "github/gpt-5.4",
        "codex/gpt-5.6-terra"
      ],
      "judge_model": "codex/gpt-5.6-terra",
      "claim_modes": [
        "DIRECT-OBSERVATION",
        "EMPIRICAL-CORRELATE",
        "TRADITIONAL-SOURCE",
        "HISTORICAL-CLAIM",
        "HOUSE-MODEL",
        "DERIVED-SYNTHESIS",
        "DECLARED-METAPHOR"
      ],
      "chat_combo_boundary": "The research council classifies and grounds claims by the Albedo Epistemic Grammar; it never drafts prose and never fabricates or launders a source."
    },
    "media": {
      "portfolio": "te-write-media",
      "strategy": "priority",
      "purpose": "Write structured brandmint/FAL image briefs in the noesis house style (Amir Musich anchors, Goethe color system, brand palette); text planning only, distinct from te-creative's generic brief.",
      "models": [
        "github/gpt-5.4",
        "codex/gpt-5.6-sol-max",
        "nebius/Qwen/Qwen3-235B-A22B-Instruct-2507"
      ],
      "chat_combo_boundary": "te-write-media plans image briefs as text only; brandmint/FAL generates client-side and never enters a chat combo."
    },
    "workflow": [
      "load-brand-voice-dna-client-side",
      "mine-vault-source-lattice-client-side",
      "ground-and-classify-claims-on-te-write-research",
      "draft-section-on-te-write",
      "score-drift-on-te-write-critique",
      "backpropagate-or-commit-section",
      "plan-images-with-te-write-media",
      "generate-images-client-side-brandmint-fal",
      "run-quality-gates-and-convergence-proof",
      "persist-trace-ledger-and-evidence-pointer"
    ],
    "transmutation_workflow": [
      "nigredo-blind-claim-extraction-on-te-write-critique",
      "albedo-ledger-classification-and-coverage-review",
      "citrinitas-surgical-transmutation-on-te-write",
      "rubedo-verification-on-te-write-critique",
      "persist-albedo-ledger-and-transmutation-trace-client-side"
    ],
    "chat_combo_boundary": "The critique and research councils score, gate, and ground but never draft; te-write drafts but never certifies its own output; te-write-media plans image briefs as text only; image generation stays client-side in brandmint/FAL and no writing combo ever enters a coding fallback chain.",
    "acp": {
      "status": "declared-inactive",
      "note": "An ACP lane is named for future editor-agent integration only; agent-protocol contracts require a separate principal-bound security design before any implementation."
    }
  }
}
